{
  "name": "pi-workflows",
  "version": "0.1.0",
  "description": "Dependency-aware multi-agent workflow execution for Pi",
  "type": "module",
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  },

  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run test/integration",
    "test:all": "vitest run",
    "test:ci": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "workflows",
    "multi-agent",
    "orchestration"
  ],
  "files": [
    "src/",
    "*.json",
    "README.md"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0"
  },
  "optionalDependencies": {
    "pi-subagents": ">=0.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typebox": "^1.1.38",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "license": "MIT",
  "author": ""
}